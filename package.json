{
  "name": "pusula",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:e2e": "eslint e2e/",
    "typecheck": "turbo run typecheck",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:seed": "tsx e2e/fixtures/seed.ts",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @pusula/db generate",
    "db:migrate": "pnpm --filter @pusula/db migrate",
    "db:push": "pnpm --filter @pusula/db push",
    "db:studio": "pnpm --filter @pusula/db studio",
    "db:seed": "pnpm --filter @pusula/db seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@pusula/config": "workspace:*",
    "@pusula/db": "workspace:*",
    "@pusula/domain": "workspace:*",
    "@types/node": "^22.19.18",
    "better-auth": "^1.6.10",
    "eslint": "^9.39.4",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
