# =========================================================================
# Pusula — environment example
# Copy this file to `.env` at the repo root (used by docker compose + the
# db tooling). Apps read their own process env; in dev they inherit `.env`
# via the dev runners. Never commit real `.env` files.
# =========================================================================

# --- Core ---
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Matches docker-compose.yml (host port 5436 to coexist with the v1 project).
DATABASE_URL=postgresql://pusula:pusula@localhost:5436/pusula

# --- Redis (queue + Socket.IO adapter) ---
REDIS_URL=redis://localhost:6380
# Prod: Redis `--requirepass` parolası; `REDIS_URL` onu taşır
# (redis://:${REDIS_PASSWORD}@redis:6379). Lokal dev'de boş — dev Redis parolasız.
REDIS_PASSWORD=

# --- Auth (Better Auth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-local-and-prod

# --- URLs / ports ---
# APP_URL: web'in herkese açık kök adresi — e-posta/push şablonlarındaki tüm
# derin bağlantıların ve /share linklerinin tabanı. Production'da MUTLAKA
# gerçek domain olmalı (örn. https://pusulaportal.com); localhost kalırsa
# api + worker prod guard'ı boot'u durdurur.
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
WEB_PORT=3000
API_PORT=3001

# --- Mobile (Expo — apps/mobile, Faz 7) ---
# EXPO_PUBLIC_*: mobil uygulama bundle'ına girer (gizli değil). Zod ile
# apps/mobile/src/env.ts'te doğrulanır.
EXPO_PUBLIC_API_URL=http://localhost:3001
# Sentry pusula-mobile projesinin DSN'i — boşsa Sentry.init no-op.
EXPO_PUBLIC_SENTRY_DSN=
# EAS CLI erişim token'ı — yalnız CI/EAS build, lokal dev'de gerekmez.
EXPO_ACCESS_TOKEN=

# --- Object storage (MinIO via S3-compatible API) ---
# Console at http://localhost:9101 (host port 9100 → MinIO S3 API).
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=pusula
# Prod: MinIO root kimliği YALNIZ minio servisinde. Lokal dev'de root = app =
# minioadmin (dev'de IAM ayrımı yok).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Uygulamanın (api/worker) S3 kimliği. Prod'da bu, `pusula` bucket'ıyla sınırlı
# dar-yetkili bir MinIO service account'tur (root DEĞİL). Dev'de = minioadmin.
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Browser-facing base URL for public bucket objects (avatars). Leave empty in
# local dev — it falls back to S3_ENDPOINT (already host-reachable). In
# production set it to the public MinIO origin (Traefik subdomain), since
# S3_ENDPOINT there is an internal-only hostname.
S3_PUBLIC_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=Pusula <no-reply@pusula.local>
# Dev only: e-posta gönderiminde gerçek alıcı yerine bu adresi kullan (prod'da yok sayılır).
# Resend "onboarding@resend.dev" gönderen adresi yalnız hesap sahibinin adresine teslim ettiği için kullanışlı.
EMAIL_DEV_OVERRIDE=

# --- Search (Meilisearch) — later phase ---
MEILISEARCH_URL=
MEILISEARCH_API_KEY=

# --- Observability (Sentry) ---
# Sentry'de 4 ayrı proje: pusula-web / pusula-api / pusula-worker / pusula-mobile.
# (pusula-mobile DSN'i yukarıdaki Mobile bölümünde — EXPO_PUBLIC_SENTRY_DSN.)
# DSN gizli değildir (yalnız olay göndermeye izin verir) — boş bırakılırsa
# Sentry.init no-op olur, lokal dev etkilenmez.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN_API=
SENTRY_DSN_WORKER=
# Source map yükleme — yalnız CI/build, opsiyonel. Boşsa source map yüklenmez.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
