{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local", "tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "AUTH_SECRET",
    "APP_URL",
    "API_URL",
    "WEB_PORT",
    "API_PORT",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_DSN_API",
    "SENTRY_DSN_WORKER",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "EXPO_ACCESS_TOKEN",
    "S3_BUCKET",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_ENDPOINT",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "MEILISEARCH_URL",
    "MEILISEARCH_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check-i18n-keys": {
      "inputs": [
        "scripts/check-i18n-keys.ts",
        "src/reports/i18n-keys.ts",
        "$TURBO_ROOT$/apps/web/src/locales/**/*.json",
        "$TURBO_ROOT$/packages/api/src/lib/locales/**/*.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
